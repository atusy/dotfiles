# Color style. See choices and the chosen by `xonfig styles`
$XONSH_COLOR_STYLE = "monokai"

# Indent with 4 spaces
$INDENT = "    "

# Auto complete neglecting upper/lower cases
$CASE_SENSITIVE_COMPLETIONS = False

# Auto complete without running
$COMPLETIONS_CONFIRM = True

# Do not save duplicated history
$HISTCONTROL = 'ignoredups'

# Complete braces
$XONSH_AUTOPAIR = True

# Input only path to `cd` wihtou `cd`
$AUTO_CD = True

# Show traceback
$XONSH_SHOW_TRACEBACK = True

# Suppress branch timeout message
$SUPPRESS_BRANCH_TIMEOUT_MESSAGE = True

# Look & Feel inspired by oh-my-fish/theme-yimmy
# http://xon.sh/tutorial.html#customizing-the-prompt

$PROMPT = "\n{RED}┌{INTENSE_GREEN}[ {cwd} ] {gitstatus}\n{RED}└{INTENSE_GREEN}>{NO_COLOR} "
$RIGHT_PROMPT = "\n{user}@{hostname}"

## Look & Feel for ls
$LS_COLORS="di=34:ln=35:so=32:pi=33:ex=31:bd=46;34:cd=43;34:su=41;30:sg=46;30:tw=42;30:ow=43;30"


# aliases

aliases['ls'] = "ls --color=auto"
aliases["la"] = "ls -a"
aliases["ll"] = "ls -l"
aliases["lla"] = "ls -la"
